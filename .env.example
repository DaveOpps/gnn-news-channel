# Neon Postgres — from Vercel dashboard → Storage tab → Postgres (Neon), or the Neon console directly.
# Pooled connection (hostname contains "-pooler") — used by the running app.
DATABASE_URL="postgres://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct/unpooled connection (no "-pooler") — used only by Prisma CLI (migrate, db seed).
DIRECT_URL="postgres://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# Vercel Blob — from Vercel dashboard → Storage tab → Blob.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Session cookie signing secret — set a real random value in production.
AUTH_SECRET="change-me"

# Bootstrap admin account (seeded once by prisma/seed.ts).
ADMIN_USER="admin"
ADMIN_PASS="change-me"
